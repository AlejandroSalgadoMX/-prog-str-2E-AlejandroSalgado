<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.login.login_dashboard.controllers.DashboardController"
      prefHeight="420.0" prefWidth="550.0"
      spacing="15">
    <padding>
        <Insets top="25" bottom="25" right="25" left="25"/>
    </padding>

    <Label fx:id="lblBienvenido" text="Bienvenido, usuario"/>

    <Button text="Salir" onAction="#Salir"/>
</VBox>