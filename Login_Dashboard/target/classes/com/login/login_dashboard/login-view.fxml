<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.login.login_dashboard.controllers.LoginController"
      prefHeight="400.0" prefWidth="500.0"
      spacing="10">
    <padding>
        <Insets top="20" bottom="20" right="20" left="20"/>
    </padding>

    <Label text="Login"/>

    <Label text="Usuario:"/>
    <TextField fx:id="TxtUsuario" promptText="Ingresa tu usuario"/>

    <Label text="Correo electrónico:"/>
    <TextField fx:id="TxtCorreo" promptText="ejemplo@correo.com"/>

    <Label text="Contraseña:"/>
    <PasswordField fx:id="TxtPassword" promptText="Ingresa la contraseña"/>

    <Button text="Entrar" onAction="#Entrar"/>

    <TextField fx:id="lblError"/>
</VBox>
